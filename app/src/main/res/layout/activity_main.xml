<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="400dp"
            android:layout_marginStart="200dp"
            android:layout_marginBottom="400dp"
            android:src="@drawable/splashart"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/id_salam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="25dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Selamat Datang"
            android:textColor="#942b9d"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Aplikasi Panduan Wisata \nKota Kyoto"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/id_salam"
            app:layout_constraintTop_toBottomOf="@id/id_salam" />

        <ImageView
            android:id="@+id/id_bannerawal"
            android:layout_width="420dp"
            android:layout_height="190dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="50dp"
            android:fontFamily="@font/roboto_bold"
            android:src="@drawable/m_infoapk"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/id_salam" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/idTentangApp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="20dp"
            android:text="Info \nAplikasi"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="@id/id_bannerawal"
            app:layout_constraintEnd_toEndOf="@+id/id_bannerawal"
            app:layout_constraintTop_toTopOf="@id/id_bannerawal"
            app:rippleColor="@color/white"
            app:strokeColor="@color/white" />

        <TextView
            android:id="@+id/id_pencarian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Pencarian"
            android:textColor="#942b9d"
            android:textSize="25sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/id_bannerawal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCari_Beranda"
            style="@style/Widget.MaterialComponents.ChipGroup"
            android:layout_width="match_parent"
            android:layout_height="67dp"
            android:layout_marginTop="5dp"
            android:layout_marginHorizontal="30dp"
            android:fontFamily="sans-serif"
            android:padding="10dp"
            android:text="Cari"
            android:textAlignment="textStart"
            android:textColor="#9E9E9E"
            android:textSize="17sp"
            app:backgroundTint="#F4F4F4"
            app:cornerRadius="15dp"
            app:icon="@drawable/ic_search2"
            app:iconSize="25dp"
            app:iconTint="#9E9E9E"
            app:rippleColor="#424242"
            app:layout_constraintEnd_toStartOf="@id/id_pencarian"
            app:layout_constraintStart_toStartOf="@id/id_pencarian"
            app:layout_constraintTop_toBottomOf="@id/id_pencarian"/>

        <TextView
            android:id="@+id/id_menukategori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Menu Kategori Wisata"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnCari_Beranda" />

        <HorizontalScrollView
            android:id="@+id/page_hori1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            app:layout_constraintEnd_toEndOf="@id/id_menukategori"
            app:layout_constraintStart_toStartOf="@id/id_menukategori"
            app:layout_constraintTop_toBottomOf="@id/id_menukategori">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent">

            <com.makeramen.roundedimageview.RoundedImageView
                android:id="@+id/kategoriBeranda1"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:adjustViewBounds="true"
                android:src="@drawable/mwisata"
                app:riv_corner_radius="10dp"
                android:foreground="?attr/selectableItemBackground" />

            <com.makeramen.roundedimageview.RoundedImageView
                android:id="@+id/kategoriBeranda2"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:adjustViewBounds="true"
                android:src="@drawable/mkuil"
                app:riv_corner_radius="10dp"
                android:foreground="?attr/selectableItemBackground"/>

            <com.makeramen.roundedimageview.RoundedImageView
                android:id="@+id/kategoriBeranda3"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:adjustViewBounds="true"
                android:src="@drawable/mfood"
                app:riv_corner_radius="10dp"
                android:foreground="?attr/selectableItemBackground"/>

            <com.makeramen.roundedimageview.RoundedImageView
                android:id="@+id/kategoriBeranda4"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:adjustViewBounds="true"
                android:src="@drawable/mfestival"
                app:riv_corner_radius="10dp"
                android:foreground="?attr/selectableItemBackground"/>
        </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/id_transportasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Menu Transportasi"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/page_hori1" />

        <HorizontalScrollView
            android:id="@+id/page_hori2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            app:layout_constraintEnd_toEndOf="@id/id_transportasi"
            app:layout_constraintStart_toStartOf="@id/id_transportasi"
            app:layout_constraintTop_toBottomOf="@id/id_transportasi">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

                <com.makeramen.roundedimageview.RoundedImageView
                    android:id="@+id/transportasi1"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/t_cover1"
                    app:riv_corner_radius="10dp"
                    android:foreground="?attr/selectableItemBackground" />

                <com.makeramen.roundedimageview.RoundedImageView
                    android:id="@+id/transportasi2"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/b_cover1"
                    app:riv_corner_radius="10dp"
                    android:foreground="?attr/selectableItemBackground"/>

            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/id_infromasitambahan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Informasi Tambahan"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/page_hori2" />

        <HorizontalScrollView
            android:id="@+id/page_hori3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            app:layout_constraintEnd_toEndOf="@id/id_infromasitambahan"
            app:layout_constraintStart_toStartOf="@id/id_infromasitambahan"
            app:layout_constraintTop_toBottomOf="@id/id_infromasitambahan">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

                <com.makeramen.roundedimageview.RoundedImageView
                    android:id="@+id/idTentangPrefektur"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/m_tentangprefektur"
                    app:riv_corner_radius="10dp"
                    android:foreground="?attr/selectableItemBackground" />

                <com.makeramen.roundedimageview.RoundedImageView
                    android:id="@+id/idTentangKyoto"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/m_tentangkyoto"
                    app:riv_corner_radius="10dp"
                    android:foreground="?attr/selectableItemBackground"/>

                <com.makeramen.roundedimageview.RoundedImageView
                    android:id="@+id/idShrinedanTample"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/m_perbedaankuil"
                    app:riv_corner_radius="10dp"
                    android:foreground="?attr/selectableItemBackground"/>
            </LinearLayout>
        </HorizontalScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>


</ScrollView>